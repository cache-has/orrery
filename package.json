{
  "name": "openboard",
  "version": "0.1.0",
  "description": "Open-source, code-defined BI dashboards. Dashboards as code, not clicks.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openboard": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/cli/dev.ts dev",
    "dev:pagila": "tsx src/cli/dev.ts dev --project examples/pagila",
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/ test/",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "validate": "tsx src/cli/validate.ts",
    "build:grammar": "node scripts/build-grammar.mjs"
  },
  "keywords": [
    "dashboard",
    "bi",
    "analytics",
    "dashboards-as-code",
    "sql"
  ],
  "author": "Cache McClure <cache@horizonanalytic.com> (Horizon Analytic Studios, LLC)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lezer/generator": "^1.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@duckdb/node-api": "^1.5.1-r.1",
    "@hono/node-server": "^1.19.11",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "echarts": "^6.0.0",
    "esbuild": "^0.28.0",
    "hono": "^4.12.9",
    "marked": "^17.0.5",
    "mysql2": "^3.20.0",
    "open": "^11.0.0",
    "pg": "^8.20.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@google-cloud/storage": "^7.19.0"
  }
}
