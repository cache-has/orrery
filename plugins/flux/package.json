{
  "name": "@openboard/flux-plugin",
  "version": "0.1.0",
  "description": "Horizon Flux sink plugin that publishes pipeline outputs to OpenBoard via DuckDB",
  "type": "module",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "author": "Horizon Analytic Studios, LLC",
  "scripts": {
    "build": "tsup",
    "bundle": "tsup && node scripts/bundle.mjs",
